generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleName {
  SUPER_ADMIN
  HR_ADMIN
  RECRUITER
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WEEK_OFF
  HOLIDAY
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentType {
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  RELIEVING_LETTER
  PAYSLIP
  ID_PROOF
  ADDRESS_PROOF
  EDUCATION
  BANK
  OTHER
}

enum JobStatus {
  DRAFT
  APPROVAL_PENDING
  APPROVED
  OPEN
  CLOSED
  ON_HOLD
}

enum CandidateStage {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  SELECTED
  OFFERED
  JOINED
  REJECTED
  ON_HOLD
}

enum CandidateSource {
  CAREERS_PORTAL
  REFERRAL
  LINKEDIN
  JOB_BOARD
  DIRECT
  AGENCY
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OnboardingStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum PerformanceCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  fullName       String
  roleId         String
  role           Role            @relation(fields: [roleId], references: [id])
  status         UserStatus      @default(ACTIVE)
  employee       Employee?
  lastLoginAt    DateTime?
  resetToken     String?
  resetTokenExp  DateTime?
  notifications  Notification[]
  auditLogs      AuditLog[]
  assignedJobs   JobOpening[]    @relation("jobRecruiter")
  candidateOwner Candidate[]     @relation("candidateRecruiter")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([roleId])
}

model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  employees   Employee[]
  requisitions JobRequisition[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
}

model Designation {
  id          String      @id @default(cuid())
  name        String      @unique
  employees   Employee[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model WorkLocation {
  id          String      @id @default(cuid())
  name        String      @unique
  city        String
  country     String
  employees   Employee[]
  jobOpenings JobOpening[]
}

model Employee {
  id                 String         @id @default(cuid())
  employeeCode       String         @unique
  userId             String?        @unique
  user               User?          @relation(fields: [userId], references: [id])
  firstName          String
  lastName           String
  personalEmail      String?
  phone              String?
  dateOfBirth        DateTime?
  joiningDate        DateTime
  employmentType     EmploymentType
  status             UserStatus     @default(ACTIVE)
  departmentId       String
  designationId      String
  managerId          String?
  workLocationId     String?
  emergencyContact   Json?
  bankDetails        Json?
  salaryMonthly      Decimal        @db.Decimal(12, 2)
  noticePeriodDays   Int            @default(30)
  skills             String[]
  timelineEvents     EmployeeEvent[]
  department         Department     @relation(fields: [departmentId], references: [id])
  designation        Designation    @relation(fields: [designationId], references: [id])
  manager            Employee?      @relation("employeeManager", fields: [managerId], references: [id])
  reportees          Employee[]     @relation("employeeManager")
  workLocation       WorkLocation?  @relation(fields: [workLocationId], references: [id])
  attendanceRecords  Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  payrollItems       PayrollItem[]
  payslips           Payslip[]
  documents          Document[]
  onboardingTasks    OnboardingTask[]
  performanceGoals   PerformanceGoal[]
  performanceReviews PerformanceReview[]
  createdFromCandId  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  @@index([departmentId, designationId])
  @@index([managerId])
}

model EmployeeEvent {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  actorUserId String?
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([employeeId, createdAt])
}

model Shift {
  id          String      @id @default(cuid())
  name        String      @unique
  startTime   String
  endTime     String
  weeklyOff   String[]
  graceMins   Int         @default(15)
  attendances Attendance[]
}

model Holiday {
  id          String    @id @default(cuid())
  name        String
  date        DateTime  @unique
  optional    Boolean   @default(false)
  locationId  String?
  createdAt   DateTime  @default(now())
}

model Attendance {
  id               String           @id @default(cuid())
  employeeId       String
  date             DateTime
  checkIn          DateTime?
  checkOut         DateTime?
  workMinutes      Int              @default(0)
  lateMinutes      Int              @default(0)
  status           AttendanceStatus @default(PRESENT)
  regularizationNote String?
  approvedByUserId String?
  shiftId          String?
  employee         Employee         @relation(fields: [employeeId], references: [id])
  shift            Shift?           @relation(fields: [shiftId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

model LeaveType {
  id             String         @id @default(cuid())
  name           String         @unique
  code           String         @unique
  annualQuota    Int
  carryForward   Boolean        @default(false)
  requests       LeaveRequest[]
  balances       LeaveBalance[]
}

model LeaveBalance {
  id           String    @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  year         Int
  allocated    Decimal   @db.Decimal(6, 2)
  used         Decimal   @db.Decimal(6, 2) @default(0)
  employee     Employee  @relation(fields: [employeeId], references: [id])
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  startDate     DateTime
  endDate       DateTime
  reason        String?
  status        LeaveStatus @default(PENDING)
  approverId    String?
  rejectionReason String?
  employee      Employee    @relation(fields: [employeeId], references: [id])
  leaveType     LeaveType   @relation(fields: [leaveTypeId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([employeeId, status])
}

model SalaryComponent {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String
  taxable     Boolean   @default(true)
}

model PayrollRun {
  id             String        @id @default(cuid())
  month          Int
  year           Int
  status         PayrollStatus @default(DRAFT)
  processedById  String?
  summaryJson    Json?
  items          PayrollItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([month, year])
}

model PayrollItem {
  id             String     @id @default(cuid())
  payrollRunId   String
  employeeId     String
  grossPay       Decimal    @db.Decimal(12, 2)
  deductions     Decimal    @db.Decimal(12, 2)
  netPay         Decimal    @db.Decimal(12, 2)
  reimbursement  Decimal    @db.Decimal(12, 2) @default(0)
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employeeId], references: [id])
  payslip        Payslip?

  @@unique([payrollRunId, employeeId])
}

model Payslip {
  id             String     @id @default(cuid())
  employeeId     String
  payrollItemId  String     @unique
  month          Int
  year           Int
  pdfPath        String?
  employee       Employee   @relation(fields: [employeeId], references: [id])
  payrollItem    PayrollItem @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
}

model Document {
  id            String       @id @default(cuid())
  employeeId    String?
  candidateId   String?
  type          DocumentType
  fileName      String
  filePath      String
  version       Int          @default(1)
  uploadedById  String?
  employee      Employee?    @relation(fields: [employeeId], references: [id])
  candidate     Candidate?   @relation(fields: [candidateId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([employeeId, type])
  @@index([candidateId, type])
}

model JobRequisition {
  id              String      @id @default(cuid())
  title           String
  departmentId    String
  budgetMin       Decimal?    @db.Decimal(12, 2)
  budgetMax       Decimal?    @db.Decimal(12, 2)
  location        String?
  employmentType  EmploymentType
  status          JobStatus   @default(DRAFT)
  approverId      String?
  notes           String?
  department      Department  @relation(fields: [departmentId], references: [id])
  opening         JobOpening?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([departmentId, status])
}

model JobOpening {
  id              String         @id @default(cuid())
  requisitionId   String         @unique
  title           String
  description     String
  locationId      String?
  workLocation    WorkLocation?  @relation(fields: [locationId], references: [id])
  status          JobStatus      @default(OPEN)
  recruiterId     String?
  openingsCount   Int            @default(1)
  publishedAt     DateTime?
  closeDate       DateTime?
  requisition     JobRequisition @relation(fields: [requisitionId], references: [id])
  recruiter       User?          @relation("jobRecruiter", fields: [recruiterId], references: [id])
  candidates      Candidate[]
  interviews      Interview[]
  offers          Offer[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, recruiterId])
}

model Candidate {
  id               String          @id @default(cuid())
  jobOpeningId     String
  fullName         String
  email            String
  phone            String?
  currentLocation  String?
  noticePeriodDays Int?
  totalExperience  Decimal?        @db.Decimal(4, 1)
  skills           String[]
  education        String?
  resumePath       String?
  parsedResume     Json?
  stage            CandidateStage  @default(APPLIED)
  source           CandidateSource @default(CAREERS_PORTAL)
  rating           Int             @default(0)
  rejectionReason  String?
  assignedRecruiterId String?
  duplicateHash    String?
  joinedEmployeeId String?
  activity         CandidateActivity[]
  documents        Document[]
  interviews       Interview[]
  feedbacks        InterviewFeedback[]
  offer            Offer?
  onboardingTasks  OnboardingTask[]
  comments         CandidateComment[]
  jobOpening       JobOpening      @relation(fields: [jobOpeningId], references: [id])
  assignedRecruiter User?          @relation("candidateRecruiter", fields: [assignedRecruiterId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([jobOpeningId, email])
  @@index([stage, source])
}

model CandidateComment {
  id           String    @id @default(cuid())
  candidateId  String
  authorId     String
  comment      String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([candidateId, createdAt])
}

model CandidateActivity {
  id           String     @id @default(cuid())
  candidateId  String
  action       String
  meta         Json?
  candidate    Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([candidateId, createdAt])
}

model Interview {
  id             String    @id @default(cuid())
  candidateId    String
  jobOpeningId   String
  scheduledById  String?
  scheduledAt    DateTime
  mode           String
  panelists      String[]
  notes          String?
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening     JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  feedback       InterviewFeedback?
  createdAt      DateTime  @default(now())
}

model InterviewFeedback {
  id             String    @id @default(cuid())
  candidateId    String
  interviewId    String    @unique
  rating         Int
  recommendation String
  strengths      String?
  concerns       String?
  createdById    String
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
}

model Offer {
  id              String      @id @default(cuid())
  candidateId      String      @unique
  jobOpeningId     String
  proposedCtc      Decimal     @db.Decimal(12, 2)
  joiningDate      DateTime?
  status           OfferStatus @default(DRAFT)
  letterPath       String?
  candidate        Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening       JobOpening  @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OnboardingTask {
  id             String           @id @default(cuid())
  title          String
  description    String?
  status         OnboardingStatus @default(TODO)
  assigneeRole   RoleName?
  dueDate        DateTime?
  employeeId     String?
  candidateId    String?
  employee       Employee?        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  candidate      Candidate?       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  title         String
  body          String
  link          String?
  readAt        DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String
  module        String
  entityId      String?
  meta          Json?
  ipAddress     String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@index([module, createdAt])
}

model Announcement {
  id            String   @id @default(cuid())
  title         String
  content       String
  publishedById String?
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  subject     String
  body        String
  updatedAt   DateTime @updatedAt
}

model AttendanceRule {
  id           String   @id @default(cuid())
  key          String   @unique
  value        Json
  updatedAt    DateTime @updatedAt
}

model RecruitmentStageConfig {
  id           String         @id @default(cuid())
  stage        CandidateStage @unique
  order        Int            @unique
  label        String
  updatedAt    DateTime       @updatedAt
}

model OrganizationSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PerformanceCycle {
  id          String                 @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      PerformanceCycleStatus @default(DRAFT)
  goals       PerformanceGoal[]
  reviews     PerformanceReview[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model PerformanceGoal {
  id          String            @id @default(cuid())
  employeeId  String
  cycleId     String
  title       String
  description String?
  targetValue Decimal?          @db.Decimal(10, 2)
  weight      Int               @default(10)
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle       PerformanceCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([employeeId, cycleId])
}

model PerformanceReview {
  id            String            @id @default(cuid())
  employeeId    String
  cycleId       String
  reviewerId    String?
  selfRating    Int?
  managerRating Int?
  notes         String?
  employee      Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle         PerformanceCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([employeeId, cycleId])
  @@index([cycleId, managerRating])
}
